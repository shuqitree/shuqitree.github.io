---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Shuqi's Forest", description = 'Photography and stories by Shuqi Jiang.' } =
  Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
