---
import CameraText from '../components/CameraText';
import RainToggle from '../components/RainToggle';
import SiteNavigation from '../components/SiteNavigation.astro';
import ThemeToggle from '../components/ThemeToggle';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title?: string | undefined;
  description?: string | undefined;
  image?: string | undefined;
  jsonLd?: Record<string, unknown> | undefined;
  noIndex?: boolean | undefined;
}

const { title, description, image, jsonLd, noIndex } = Astro.props;
const isHome = Astro.url.pathname === '/';
---

<BaseLayout title={title} description={description} image={image} jsonLd={jsonLd} noIndex={noIndex}>
  <div class="site-shell">
    <aside class="site-sidebar">
      <SiteNavigation currentPath={Astro.url.pathname} />
      <CameraText client:load />
    </aside>

    <main class="site-main">
      {
        !isHome && (
          <div class="site-theme-control" aria-label="Site weather and appearance">
            <RainToggle client:load />
            <ThemeToggle client:load />
          </div>
        )
      }
      <slot />
    </main>
  </div>

  <div class="site-watermark" aria-hidden="true">
    <img src="/logo.png" alt="" />
  </div>
</BaseLayout>
