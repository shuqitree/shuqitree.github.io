---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

const photography = await getCollection('photography');
const pages = await getCollection('pages');
const publishedProjects = photography.filter(({ data }) => data.status === 'published');
const draftProjects = photography.filter(({ data }) => data.status === 'draft');
---

<BaseLayout>
  <main class="migration-placeholder">
    <p class="eyebrow">Astro migration workspace</p>
    <h1>Shuqi's Forest</h1>
    <p>
      The new static site foundation is ready. Photography content and the existing visual design
      will be migrated in the next stages.
    </p>
    <p class="content-status">
      {publishedProjects.length} published projects, {draftProjects.length} drafts, and {
        pages.length
      }
      profile page are now validated by the content model.
    </p>
  </main>
</BaseLayout>
