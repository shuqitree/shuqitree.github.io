---
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';

import PhotoTree from '../components/PhotoTree';
import SiteLayout from '../layouts/SiteLayout.astro';
import { resolveMedia } from '../lib/images';

const photography = await getCollection('photography');
const publishedProjects = photography
  .filter(({ data }) => data.status === 'published' && data.cover)
  .sort((a, b) => a.data.order - b.data.order);
const treeEntries = await Promise.all(
  publishedProjects.map(async (entry) => ({
    id: entry.id,
    title: entry.data.title,
    href: `/${entry.id}`,
    image: (
      await getImage({
        src: resolveMedia(entry.data.cover!),
        width: 420,
        format: 'webp',
        quality: 76,
      })
    ).src,
  })),
);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: "Shuqi's Forest",
  url: Astro.site,
  author: {
    '@type': 'Person',
    name: 'Shuqi Jiang',
  },
};
---

<SiteLayout jsonLd={jsonLd}>
  <section class="home-tree" aria-labelledby="home-title">
    <h1 id="home-title" class="visually-hidden">Shuqi's Forest</h1>
    <p class="tree-instruction">Drag a photograph. Follow a branch.</p>
    <PhotoTree entries={treeEntries} client:load />
  </section>
</SiteLayout>
